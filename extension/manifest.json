{
  "manifest_version": 3,
  "name": "Lizhi Routine — Capture",
  "version": "0.1.0",
  "description": "Attach the current page to a Lizhi Routine todo as AI context.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Capture this page to Lizhi Routine",
    "default_popup": "popup/popup.html"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+L",
        "mac": "Alt+L"
      },
      "description": "Open the Lizhi Routine capture popup"
    }
  }
}
