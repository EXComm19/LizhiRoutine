# Lizhi Routine 鈥?Supabase config
# Copy this file to `.env.local` and fill in the values from your Supabase
# project: Project Settings 鈫?API.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Required for /api/extension/* routes (Chrome extension API). The extension
# authenticates with a Bearer token (user_api_tokens table); after that the
# server uses this key to bypass RLS when reading/writing the user's state.
# Find it under Supabase Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# Kimi todo parser + estimator (all default to kimi-k2.6)
# Three routes call Moonshot: /api/parse-todos uses KIMI_TODO_PARSER_MODEL,
# /api/estimate-todo prefers KIMI_ESTIMATE_MODEL (falls back to TODO_PARSER),
# and the Gmail email-suggestion parser uses KIMI_EMAIL_PARSER_MODEL.
# Set them all to kimi-k2.6 explicitly so a future default change in source
# can't silently route any call to a different model.
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
KIMI_TODO_PARSER_MODEL=kimi-k2.6
KIMI_ESTIMATE_MODEL=kimi-k2.6

# Commute estimator (server-side Mapbox calls)
MAPBOX_ACCESS_TOKEN=
MAPBOX_MONTHLY_REQUEST_LIMIT=100000

# Gmail reminder suggestions
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/gmail/auth/callback
# Required. Used to AES-256-GCM encrypt Gmail access/refresh tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
GMAIL_TOKEN_ENCRYPTION_KEY=
GMAIL_SCAN_MAX_MESSAGES=50
GMAIL_MESSAGE_TEXT_MAX_CHARS=6000
GMAIL_FETCH_CONCURRENCY=5
# Server-side cap on how many messages /api/gmail/scan/run will process
# per request. Lower this if your serverless function timeout is shorter
# than ~10s and a single chunk is overshooting.
GMAIL_RUN_CHUNK_MAX=12
# When true, prints from / subject / snippet / body preview to server logs.
# Keep this off unless you are debugging — the output contains email PII.
GMAIL_SCAN_DEBUG=false
GMAIL_KIMI_BATCH_MESSAGES=5
GMAIL_KIMI_BATCH_MAX_CHARS=18000
KIMI_EMAIL_PARSER_MODEL=kimi-k2.6
